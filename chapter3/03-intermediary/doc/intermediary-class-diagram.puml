@startuml
title Chapter 3.03 - Intermediary Pattern Class Model

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam linetype polyline
top to bottom direction

together {
  class main {
    +main(argc, argv)
  }

  class RobotArmManager {
    +currentStep : unsigned int
    +nSteps : unsigned int
    +status : int
    --
    +computeTrajectory(x, y, z, t)
    +executeStep() : int
    +graspAt(x, y, z, t) : int
    +zero() : int
  }
}

class Action {
  +rotatingArmJoint1 : int
  +rotatingArmJoint2 : int
  +rotatingArmJoint3 : int
  +rotatingArmJoint4 : int
  +slidingArmJoint1 : int
  +slidingArmJoint2 : int
  +manipulatorForce : int
  +manipulatorOpen : int
}

interface iRoatingJoint {
  +getRotation()
  +rotate(x)
  +zero()
}

interface iSlidingJoint {
  +getLength()
  +setLength(x)
  +zero()
}

together {
  class RotatingArmJoint {
    +angle : int
    +deviceID : char
    --
    +getRotation() : int
    +rotate(x) : int
    +zero() : int
  }

  class SlidingArmJoint {
    +currentLength : int
    +deviceID : int
    +minArmLength : int
    +maxArmLength : int
    --
    +getLength() : int
    +setLength(x) : int
    +zero() : int
  }

  class GraspingManipulator {
    +maxForce : int
    --
    +setMaxForce(maxForce) : int
    +open() : int
    +close() : int
  }
}

together {
  iRoatingJoint -[hidden]-> iSlidingJoint
  RotatingArmJoint -[hidden]-> SlidingArmJoint
  SlidingArmJoint -[hidden]-> GraspingManipulator
}

main ..> RobotArmManager : uses

RobotArmManager *-- "0..99" Action : action plan
RobotArmManager --> "0..4" RotatingArmJoint : coordinates
RobotArmManager --> "0..2" SlidingArmJoint : coordinates
RobotArmManager --> "1" GraspingManipulator : coordinates

RotatingArmJoint ..|> iRoatingJoint
SlidingArmJoint ..|> iSlidingJoint

Action -[hidden]-> RotatingArmJoint

note right of RobotArmManager
Acts as the intermediary/mediator.
Clients ask it for high-level work,
and it coordinates the arm devices.
end note

note bottom of Action
One action stores a full set of
joint/manipulator commands for
a single execution step.
end note

note right of RotatingArmJoint
Concrete rotating joint device.
end note

note right of SlidingArmJoint
Concrete sliding joint device.
end note

note right of GraspingManipulator
End effector controlled through
the manager.
end note

@enduml
